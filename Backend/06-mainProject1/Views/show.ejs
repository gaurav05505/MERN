<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body>
    <div class="h-screen w-full bg-black text-white p-10 flex flex-col gap-10 ">

        <!-- back button  -->
         <div class="flex gap-5">
            <button class="w-full py-3.5 bg-cyan-600  rounded-xl " ><a href="/">Go Back</a></button>
            <button class="w-full py-3.5 bg-amber-400  rounded-xl " ><a href="/">Edit File Name</a></button>
            <button class="w-full py-3.5 bg-amber-400  rounded-xl " ><a href="/">Edit Note</a></button>
         </div>

        <!-- title  -->
         <div class="mb-5 w-full h-30 rounded-xl bg-zinc-900 flex justify-center items-center ">
            <h2 class="text-5xl font-bold text-white/60  ">
                <%= title %>
            </h2>
         </div>

        <!-- body  -->
         <div class="w-full h-full bg-zinc-900 rounded-xl p-5 ">
            <h3 class="text-xl font-normal ">
                <p><%- note %></p>
            </h3>
         </div>


    </div>
</body>
</html>