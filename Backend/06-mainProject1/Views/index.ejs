<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>

    <!-- Stable Tailwind CDN -->
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body>
    <div class="h-screen w-full bg-black text-white/72 p-10 flex flex-col gap-10 ">
        
        <!-- text area  -->
        <div>
            <h1 class="text-4xl font-bold mb-8">Create Your Notes</h1>

            <form action="/create" method="post">
                <div class="flex flex-col gap-5">
                    <input class="w-full  bg-zinc-900 outline-none border border-white/22 px-8 py-4 rounded-xl " name="title" placeholder="Title" type="text">
                    
                    <textarea class="w-full  bg-zinc-900 outline-none border border-white/22 px-8 py-4 rounded-xl resize-none " placeholder="Write your task details.. " name="note" id="task"></textarea>
                </div>

                <button class="px-8 py-4 w-full mt-10 rounded-xl bg-cyan-600">Create Note</button>
            </form>
        </div>

        <!-- notes  -->
        <div>

            <h2 class="text-4xl font-bold text-white/52 mb-8 ">Your Notes</h2>

            <div class="flex gap-4 ">

                <% if(files.length > 0){%>

                    <% files.forEach((val) => {%>

                        

                        <div class=" h-60 w-60 px-5 py-5 bg-zinc-900 rounded-xl border border-zinc-800 ">
                            <h3 class="text-2xl text-center font-bold mb-6"> <%= val.title %> </h3>
                            <div>
                                <p class="text-[16px] font-medium text-white/52 line-clamp-3 mb-5 overflow-hidden ">
                                    <%= val.note %>
                                </p>
                                <button class="w-full py-3.5 bg-cyan-600  rounded-xl "><a href="/file/<%= val.title %>">Read More</a></button>
                            </div>
                        </div>


                    <%})%>
                 
                <%}else{
                    %> 
                    <h3 class="text-2xl text-center font-bold mb-6  text-zinc-900">
                        No Notes Yet Please Create Notes First.
                    </h3>
                    <%
                }  %>


            </div>

        </div>
    </div> 
</body>
</html>