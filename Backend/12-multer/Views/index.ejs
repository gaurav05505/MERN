<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body>
    <div class="h-screen w-full bg-black text-white p-5 flex flex-col  items-center ">
        <h1 class="text-7xl font-bold text-white/40 mb-20 ">Create Your Account</h1>
        <div>
            <form 
            class="flex flex-col gap-5 "
            action="/upload" method="post" enctype="multipart/form-data">

                <input type="file" name="image">

                <button class="py-4 mt-10 bg-emerald-800 w-1xs border rounded-2xl border-zinc-900 px-4" >Create Account</button>

            </form>
        </div>
    </div>
</body>
</html>