<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href = '\public\stylesheets\style.css'>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body>
    <div class="bg-black h-screen w-full p-10 text-white " >
        <button class="px-8 py-4 mt-10  rounded-xl border mb-15 hover:bg-amber-600  border-amber-600 "><a href="/">User Form</a></button>

        <div class="flex gap-5 flex-wrap ">
            
            <% user.forEach((AlUser) => { %>
                <div class="w-80 p-5 rounded-xl bg-zinc-900">
                    <div class="w-full h-40 rounded-xl bg-amber-400 " >
                        <img class="h-full w-full object-center " src="<%= AlUser.image %>" alt="">
                    </div>
                    <div class="mt-5">
                        <h2 class="text-2xl text-white/70 font-medium "><%= AlUser.Uname %></h2>
                        <h2 class=" text-[16px] text-white/50 mt-2.5 font-medium " ><%= AlUser.email %></h2>
                    </div>

                    <div class="mt-10 flex w-full items-center justify-between" >
                        <a class="text-yellow-200 " href="/edit/<%= AlUser._id %>">Edit user</a>
                        <a class="text-red-400 " href="/delete/<%= AlUser._id %>">Delete user</a>
                    </div>
                </div>
            <% }) %>

        </div>


    </div>
</body>
</html>