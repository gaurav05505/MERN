<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href = '\public\stylesheets\style.css'>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body>
    <div class="bg-black h-screen w-full p-10 text-white ">
        <button class="px-8 py-4 mt-10  rounded-xl border mb-15 hover:bg-amber-600  border-amber-600 "><a href="/read">Read User Data</a></button>

        <h1 class="text-5xl font-bold text-white/70 mb-10 ">User form</h1>

        <form class="flex gap-5 " action="/create" method="post">
            <div class="flex flex-col gap-2.5">
                <label class="text-[14px] font-light text-white/52 " for="name">Enter your Name</label>
                <input class="px-4 py-4 w-58 outline-none rounded-xl border border-zinc-800 "  type="text" name="Uname" placeholder="Enter your name..">
            </div>

            <div class="flex flex-col gap-2.5">
                <label class="text-[14px] font-light text-white/52 " for="name">Enter your Email</label>
                <input class="px-4 py-4 w-58 outline-none rounded-xl border border-zinc-800 "  type="text" name="email" placeholder="Enter your Email..">
            </div>

            <div class="flex flex-col gap-2.5">
                <label class="text-[14px] font-light text-white/52 " for="name">Give your image</label>
                <input class="px-4 py-4 w-58 outline-none rounded-xl border border-zinc-800 "  type="text" name="image" placeholder="Image Url">
            </div>

            <button class="px-85 py-4 mt-10  rounded-xl bg-amber-600 ">Submit</button>

        </form>
        


    </div>
</body>
</html>