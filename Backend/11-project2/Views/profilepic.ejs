<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body>
    <div class="h-screen w-full bg-black text-white p-5 flex flex-col  items-center ">
        <h1 class="text-7xl font-bold text-white/40 mb-20 ">Change your profile pic</h1>
        <div>
            <form 
            class="flex flex-col gap-5 "
            action="/upload" method="post" enctype="multipart/form-data">

                <label class="px-5 py-3  text-white rounded-lg cursor-pointer border border-white ">
                    Upload Image
                    <input type="file" name="image" class="hidden">
                </label>

                <div>
                    <button class="py-4 mt-10  w-xs border rounded-2xl border-zinc-900 px-4" ><a href="/profile">Go Back</a></button>
                    <button class="py-4 mt-10 bg-emerald-800 w-xs border rounded-2xl border-zinc-900 px-4" >Confirm Pic</button>
                </div>

            </form>
        </div>
    </div>
</body>
</html>